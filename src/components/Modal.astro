---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div id={id} class="modal" hidden data-modal-root>
  <div class="modal__backdrop"></div>
  <div class="modal__content">
    <div class="modal__header">
      <h3>{title}</h3>
      <button class="modal__close" data-modal-close={id}>&times;</button>
    </div>
    <div class="modal__body">
      <slot />
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .modal[hidden] {
    display: none;
  }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .modal__content {
    position: relative;
    background: var(--color-surface);
    border: var(--border-thick);
    box-shadow: 12px 12px 0px 0px var(--color-border);
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: var(--border-thick);
  }

  .modal__header h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .modal__close {
    background: none;
    border: none;
    font-size: var(--text-2xl);
    cursor: pointer;
    padding: 0;
    line-height: 1;
    color: var(--color-text);
    transition: transform var(--dur-fast) var(--steps-small);
  }

  .modal__close:hover {
    transform: scale(1.2);
  }

  .modal__body {
    padding: var(--space-6);
  }
</style>

<script>
  // 模态框位置管理：打开时移到 body，关闭时移回原位
  const modalParents = new Map<string, Element>();

  function initModal(modal: HTMLElement) {
    const id = modal.id;
    // 记录原始父元素
    modalParents.set(id, modal.parentElement!);
  }

  // 初始化所有模态框
  document.querySelectorAll('[data-modal-root]').forEach((el) => {
    initModal(el as HTMLElement);
  });

  // 监听模态框打开/关闭
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'hidden') {
        const modal = mutation.target as HTMLElement;
        if (!modal.hasAttribute('data-modal-root')) return;

        const id = modal.id;
        const originalParent = modalParents.get(id);

        if (!modal.hidden) {
          // 打开：移到 body
          document.body.appendChild(modal);
        } else if (originalParent) {
          // 关闭：移回原位
          originalParent.appendChild(modal);
        }
      }
    });
  });

  // 观察所有模态框
  document.querySelectorAll('[data-modal-root]').forEach((el) => {
    observer.observe(el, { attributes: true, attributeFilter: ['hidden'] });
  });
</script>
