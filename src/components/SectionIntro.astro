---
import Button from '@/components/Button.astro';

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
}

const {
  eyebrow,
  title,
  description,
  actionLabel,
  actionHref,
} = Astro.props;
---

<div class="section-intro">
  <div class="section-intro__copy">
    <p class="text-label section-intro__eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p class="section-intro__description">{description}</p>}
  </div>
  {actionLabel && actionHref && <Button label={actionLabel} href={actionHref} variant="ghost" />}
</div>

<style>
  .section-intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .section-intro__eyebrow {
    margin-bottom: var(--space-3);
  }

  .section-intro__description {
    margin-bottom: 0;
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .section-intro h2 {
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .section-intro {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

