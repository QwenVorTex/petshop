---
interface Props {
  status: string;
}

const { status } = Astro.props;

function resolveTone(value: string) {
  if (value.includes('完成')) return 'success';
  if (value.includes('取消') || value.includes('缺货')) return 'danger';
  if (value.includes('观察')) return 'warning';
  if (value.includes('预订') || value.includes('预约') || value.includes('待到店')) return 'info';
  if (value.includes('在售')) return 'accent';
  return 'neutral';
}
---

<span class:list={['status-pill', `status-pill--${resolveTone(status)}`]}>{status}</span>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.25rem;
    padding: 0.35rem 0.7rem;
    border: var(--border-medium);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    background: var(--color-surface);
  }

  .status-pill--accent {
    background: var(--color-accent);
  }

  .status-pill--info {
    background: var(--color-link);
    color: var(--color-surface);
  }

  .status-pill--warning {
    background: #fff0b8;
  }

  .status-pill--danger {
    background: var(--color-action);
    color: var(--color-surface);
  }

  .status-pill--success {
    background: #d8ffd8;
  }
</style>

