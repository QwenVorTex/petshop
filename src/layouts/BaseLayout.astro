---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import BrutalistCursor from '@/components/BrutalistCursor.astro';
import { siteConfig } from '@/config/site';

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
}

const {
  title,
  description = siteConfig.description,
  keywords = [],
} = Astro.props;

const siteURL = Astro.site ?? new URL(siteConfig.url);
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const pageTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.shortName}`;
---

<!DOCTYPE html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFCB2F" />
    <meta name="generator" content={Astro.generator} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <BrutalistCursor />
    <Header />
    <main id="main-content" class="anim-page-enter">
      <slot />
    </main>
    <Footer />
    <ScrollReveal />

    <style is:global>
      @import '@/styles/global.css';
    </style>
  </body>
</html>
