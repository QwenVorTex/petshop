---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Modal from '@/components/Modal.astro';
import PageHero from '@/components/PageHero.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import StatusPill from '@/components/StatusPill.astro';
import { getCustomerReservationRows } from '@/data/db';
import { formatCurrency, formatDate, formatDateTime } from '@/lib/format';

const customerRows = await getCustomerReservationRows();
const activeCustomers = customerRows.filter((item) => item.activeReservationCount > 0).length;
const totalCompletedValue = customerRows.reduce((sum, item) => sum + item.completedValue, 0);
const latestCustomer = customerRows.reduce((latest, current) =>
  Date.parse(current.createdAt) > Date.parse(latest.createdAt) ? current : latest,
);
---

<BaseLayout title="顾客管理" description="顾客档案与预约关系页面。">
  <PageHero
    eyebrow="Customer CRM"
    title="顾客与预约关系"
    subtitle="顾客联系方式、预约状态和意向宠物一览。"
    panelTitle="顾客概览"
    stats={[
      { value: customerRows.length, label: '顾客总数' },
      { value: activeCustomers, label: '活跃预约顾客' },
      { value: formatCurrency(totalCompletedValue), label: '已完成成交额' },
    ]}
    tone="action"
  >
    <button class="btn btn--primary" id="btn-add-customer">添加顾客</button>
    <Button label="查看预约页" href="/preorders" variant="ghost" />
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Customer Cards"
        title="当前顾客概览"
        description={`最新录入顾客为 ${latestCustomer.customerName}，注册时间 ${formatDate(latestCustomer.createdAt)}。`}
      />

      <div class="grid grid--3">
        {customerRows.map((customer) => (
          <article class="card scroll-reveal" data-customer-id={customer.customerId}>
            <div class="customer-card__top">
              <span class="badge">#{customer.customerId}</span>
              <StatusPill status={customer.latestStatus} />
            </div>
            <h3>{customer.customerName}</h3>
            <p>{customer.phone}</p>
            <ul class="panel-list">
              <li><span>活跃预约</span><strong>{customer.activeReservationCount}</strong></li>
              <li><span>累计预约</span><strong>{customer.reservationCount}</strong></li>
              <li><span>意向宠物</span><strong>{customer.interestedPets}</strong></li>
            </ul>
            <div class="card-actions">
              <button class="btn btn--sm btn-edit-customer" data-customer={JSON.stringify(customer)}>编辑</button>
              <button class="btn btn--sm btn--danger btn-delete-customer" data-customer-id={customer.customerId} data-customer-name={customer.customerName}>删除</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="Table"
        title="顾客与预约明细"
        description=""
      />

      <article class="card card--flat scroll-reveal">
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>顾客</th>
                <th>电话</th>
                <th>最近预约</th>
                <th>状态</th>
                <th>预约数</th>
                <th>已完成成交额</th>
              </tr>
            </thead>
            <tbody>
              {customerRows.map((customer) => (
                <tr>
                  <td>
                    <strong>{customer.customerName}</strong>
                    <div>{customer.interestedPets}</div>
                  </td>
                  <td>{customer.phone}</td>
                  <td>{formatDateTime(customer.lastReservationTime)}</td>
                  <td><StatusPill status={customer.latestStatus} /></td>
                  <td>{customer.reservationCount}</td>
                  <td>{formatCurrency(customer.completedValue)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </section>

  <!-- 添加/编辑顾客模态框 -->
  <Modal id="customer-modal" title="添加顾客">
    <form id="customer-form">
      <input type="hidden" id="customer-id" name="customerId" />
      <div class="form-group">
        <label for="customer-name">姓名 *</label>
        <input type="text" id="customer-name" name="customerName" required />
      </div>
      <div class="form-group">
        <label for="customer-phone">电话 *</label>
        <input type="tel" id="customer-phone" name="phone" required />
      </div>
      <div class="form-group">
        <label for="customer-id-card">身份证号 *</label>
        <input type="text" id="customer-id-card" name="idCard" maxlength="18" required />
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn--ghost" data-modal-close="customer-modal">取消</button>
        <button type="submit" class="btn btn--primary">保存</button>
      </div>
    </form>
  </Modal>

  <!-- 删除确认对话框 -->
  <div id="confirm-dialog" class="confirm-dialog" hidden>
    <div class="confirm-dialog__backdrop"></div>
    <div class="confirm-dialog__content">
      <h4>确认删除</h4>
      <p id="confirm-message">确定要删除该顾客吗？</p>
      <div class="confirm-dialog__actions">
        <button class="btn btn--ghost" id="confirm-cancel">取消</button>
        <button class="btn btn--danger" id="confirm-ok">删除</button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .customer-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
</style>

<script>
  // 模态框控制
  function openModal(id: string) {
    const modal = document.getElementById(id);
    if (modal) modal.hidden = false;
  }

  function closeModal(id: string) {
    const modal = document.getElementById(id);
    if (modal) modal.hidden = true;
  }

  // 确认对话框
  let confirmCallback: (() => void) | null = null;

  function showConfirm(message: string, callback: () => void) {
    const dialog = document.getElementById('confirm-dialog');
    const msg = document.getElementById('confirm-message');
    if (dialog && msg) {
      msg.textContent = message;
      dialog.hidden = false;
      confirmCallback = callback;
    }
  }

  function hideConfirm() {
    const dialog = document.getElementById('confirm-dialog');
    if (dialog) dialog.hidden = true;
    confirmCallback = null;
  }

  // 关闭模态框按钮
  document.querySelectorAll('[data-modal-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal-close');
      if (modalId) closeModal(modalId);
    });
  });

  // 背景点击关闭模态框
  document.querySelectorAll('.modal__backdrop').forEach((backdrop) => {
    backdrop.addEventListener('click', () => {
      const modal = backdrop.closest('.modal');
      if (modal) (modal as HTMLElement).hidden = true;
    });
  });

  // 添加顾客按钮
  document.getElementById('btn-add-customer')?.addEventListener('click', () => {
    const form = document.getElementById('customer-form') as HTMLFormElement;
    form.reset();
    (document.getElementById('customer-id') as HTMLInputElement).value = '';
    const modal = document.getElementById('customer-modal');
    if (modal) {
      modal.querySelector('h3')!.textContent = '添加顾客';
    }
    openModal('customer-modal');
  });

  // 编辑顾客按钮
  document.querySelectorAll('.btn-edit-customer').forEach((btn) => {
    btn.addEventListener('click', () => {
      const customer = JSON.parse(btn.getAttribute('data-customer') || '{}');
      (document.getElementById('customer-id') as HTMLInputElement).value = customer.customerId;
      (document.getElementById('customer-name') as HTMLInputElement).value = customer.customerName;
      (document.getElementById('customer-phone') as HTMLInputElement).value = customer.phone;
      (document.getElementById('customer-id-card') as HTMLInputElement).value = customer.idCard || '';
      const modal = document.getElementById('customer-modal');
      if (modal) {
        modal.querySelector('h3')!.textContent = '编辑顾客';
      }
      openModal('customer-modal');
    });
  });

  // 删除顾客按钮
  document.querySelectorAll('.btn-delete-customer').forEach((btn) => {
    btn.addEventListener('click', () => {
      const customerId = btn.getAttribute('data-customer-id');
      const customerName = btn.getAttribute('data-customer-name');
      showConfirm(`确定要删除顾客"${customerName}"吗？`, async () => {
        try {
          const res = await fetch('/api/customers', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ customerId: Number(customerId) }),
          });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            alert('删除失败：' + (data.message || '未知错误'));
          }
        } catch (err) {
          alert('删除失败：网络错误');
        }
      });
    });
  });

  // 确认对话框按钮
  document.getElementById('confirm-ok')?.addEventListener('click', () => {
    if (confirmCallback) confirmCallback();
    hideConfirm();
  });

  document.getElementById('confirm-cancel')?.addEventListener('click', hideConfirm);
  document.getElementById('confirm-dialog')?.querySelector('.confirm-dialog__backdrop')?.addEventListener('click', hideConfirm);

  // 表单提交
  document.getElementById('customer-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const customerId = (document.getElementById('customer-id') as HTMLInputElement).value;
    const data = {
      customerName: (document.getElementById('customer-name') as HTMLInputElement).value,
      phone: (document.getElementById('customer-phone') as HTMLInputElement).value,
      idCard: (document.getElementById('customer-id-card') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/customers', {
        method: customerId ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(customerId ? { ...data, customerId: Number(customerId) } : data),
      });
      const result = await res.json();
      if (result.success) {
        closeModal('customer-modal');
        window.location.reload();
      } else {
        alert('保存失败：' + (result.message || '未知错误'));
      }
    } catch (err) {
      alert('保存失败：网络错误');
    }
  });
</script>
