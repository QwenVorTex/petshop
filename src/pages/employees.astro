---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import PageHero from '@/components/PageHero.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import { getEmployeeAssignmentRows } from '@/data/db';
import { formatCurrency, formatDateTime } from '@/lib/format';

const employeeRows = await getEmployeeAssignmentRows();
const monthlyPayroll = employeeRows.reduce((sum, item) => sum + item.salary, 0);
const averageAge = Math.round(employeeRows.reduce((sum, item) => sum + item.age, 0) / employeeRows.length);
const totalManagedQty = employeeRows.reduce((sum, item) => sum + item.managedQty, 0);
---

<BaseLayout title="员工管理" description="员工资料和宠物分工页面。">
  <PageHero
    eyebrow="Staff Ops"
    title="员工与负责关系"
    subtitle="employee 表和 employee_pet_manage 关系表已经合并为工作负载面板。后续换成真实数据库时，只需要保持相同字段输出。"
    panelTitle="团队概览"
    stats={[
      { value: employeeRows.length, label: '员工总数' },
      { value: formatCurrency(monthlyPayroll), label: '月度工资' },
      { value: totalManagedQty, label: '负责宠物数' },
    ]}
  >
    <Button label="查看接口" href="/api/employees" />
    <Button label="返回仪表盘" href="/" variant="ghost" />
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Team Cards"
        title="员工负载卡片"
        description={`当前团队平均年龄 ${averageAge} 岁。卡片里先保留工资、负责数量和职责摘要三个最关键的信息块。`}
      />

      <div class="grid grid--3">
        {employeeRows.map((employee) => (
          <article class="card scroll-reveal">
            <div class="employee-card__top">
              <span class="badge">{employee.gender}</span>
              <span class="employee-card__salary">{formatCurrency(employee.salary)}</span>
            </div>
            <h3>{employee.employeeName}</h3>
            <p>{employee.phone} · {employee.age} 岁</p>
            <ul class="panel-list">
              <li><span>负责宠物</span><strong>{employee.managedPets}</strong></li>
              <li><span>负责数量</span><strong>{employee.managedQty}</strong></li>
              <li><span>职责摘要</span><strong>{employee.dutySummary}</strong></li>
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="Assignments"
        title="员工分工明细"
        description="这个表是未来做排班、绩效或角色权限时最容易继续扩展的起点。"
      />

      <article class="card card--flat scroll-reveal">
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>员工</th>
                <th>电话</th>
                <th>工资</th>
                <th>负责宠物</th>
                <th>负责数量</th>
                <th>最近分配</th>
              </tr>
            </thead>
            <tbody>
              {employeeRows.map((employee) => (
                <tr>
                  <td>
                    <strong>{employee.employeeName}</strong>
                    <div>{employee.dutySummary}</div>
                  </td>
                  <td>{employee.phone}</td>
                  <td>{formatCurrency(employee.salary)}</td>
                  <td>{employee.petLabels}</td>
                  <td>{employee.managedQty}</td>
                  <td>{formatDateTime(employee.latestAssignment)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .employee-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .employee-card__salary {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 900;
  }
</style>

