---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import MetricCard from '@/components/MetricCard.astro';
import PageHero from '@/components/PageHero.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import StatusPill from '@/components/StatusPill.astro';
import {
  getDashboardSnapshot,
  getEmployeeAssignmentRows,
  getFeaturedPets,
  getLowStockAlerts,
  getRecentPreorders,
} from '@/data/db';
import { formatCurrency, formatDateTime } from '@/lib/format';

const snapshot = await getDashboardSnapshot();
const featuredPets = await getFeaturedPets(3);
const lowStockAlerts = (await getLowStockAlerts()).slice(0, 4);
const recentPreorders = (await getRecentPreorders(4));
const staffLoad = (await getEmployeeAssignmentRows()).slice(0, 4);

const metrics = [
  {
    label: '在售宠物',
    value: snapshot.petsOnSale,
    detail: `平均单价 ${formatCurrency(snapshot.averagePetPrice)}`,
    tone: 'accent' as const,
  },
  {
    label: '待处理预约',
    value: snapshot.pendingPreorders,
    detail: `${snapshot.completedPreorders} 条已完成`,
    tone: 'link' as const,
  },
  {
    label: '低库存提醒',
    value: snapshot.lowStockCount,
    detail: `库存总量 ${snapshot.totalInventory}`,
    tone: 'action' as const,
  },
  {
    label: '月度工资预算',
    value: formatCurrency(snapshot.monthlyPayroll),
    detail: `${snapshot.employeeCount} 名员工`,
    tone: 'neutral' as const,
  },
];

---

<BaseLayout title="PetShop OPS" description="宠物商店系统仪表盘。">
  <PageHero
    eyebrow="Pet Shop System"
    title="宠物商店管理系统"
    subtitle="围绕宠物、库存、顾客、员工和预约五大模块构建的运营管理平台。"
    panelTitle="数据概览"
    stats={[
      { value: snapshot.petCount, label: '宠物记录' },
      { value: snapshot.customerCount, label: '顾客档案' },
      { value: snapshot.employeeCount, label: '员工账号' },
    ]}
  >
    <Button label="查看宠物档案" href="/pets" />

    <div slot="visual" class="hero-matrix" aria-hidden="true">
      <div class="hero-matrix__cell hero-matrix__cell--accent">PET</div>
      <div class="hero-matrix__cell hero-matrix__cell--link">STOCK</div>
      <div class="hero-matrix__cell hero-matrix__cell--action">CRM</div>
      <div class="hero-matrix__cell hero-matrix__cell--border">OPS</div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Dashboard"
        title="核心指标"
        description="宠物、库存、预约和员工的核心运营指标。"
      />

      <div class="grid grid--4">
        {metrics.map((item) => (
          <MetricCard label={item.label} value={item.value} detail={item.detail} tone={item.tone} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="Pet Spotlight"
        title="当前重点宠物"
        description="在售和高价值宠物一览。"
        actionLabel="进入宠物页"
        actionHref="/pets"
      />

      <div class="grid grid--3">
        {featuredPets.map((pet) => (
          <article class="featured-card card scroll-reveal">
            <div class="featured-card__top">
              <p class="text-label">#{pet.petId} · {pet.petSpecies}</p>
              <StatusPill status={pet.petStatus} />
            </div>
            <h3>{pet.petName}</h3>
            <p class="featured-card__price">{formatCurrency(pet.petPrice)}</p>
            <p>{pet.petColor} · {pet.petAge} 个月 · 当前负责 {pet.managers}</p>
            <div class="featured-card__footer">
              <span>库存 {pet.inventory?.quantity ?? 0}</span>
              <span>仓位 {pet.inventory?.warehouseLocation ?? '待安排'}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Operations"
        title="今日运营面板"
        description=""
      />

      <div class="board-grid">
        <article class="card card--flat scroll-reveal">
          <div class="board-card__header">
            <h3>低库存提醒</h3>
            <span class="badge">Inventory</span>
          </div>
          <ul class="board-list">
            {lowStockAlerts.map((item) => (
              <li>
                <div>
                  <strong>{item.petName}</strong>
                  <p>{item.petSpecies} · {item.warehouseLocation}</p>
                </div>
                <div class="board-list__meta">
                  <StatusPill status={item.quantity <= 1 ? '缺货风险' : '笼位不足'} />
                </div>
              </li>
            ))}
          </ul>
        </article>

        <article class="card card--flat scroll-reveal">
          <div class="board-card__header">
            <h3>最近预约</h3>
            <span class="badge">Preorders</span>
          </div>
          <ul class="board-list">
            {recentPreorders.map((item) => (
              <li>
                <div>
                  <strong>{item.customerName}</strong>
                  <p>{item.petName} · {item.petSpecies}</p>
                </div>
                <div class="board-list__meta">
                  <StatusPill status={item.preorderStatus} />
                  <span>{formatDateTime(item.preorderTime)}</span>
                </div>
              </li>
            ))}
          </ul>
        </article>

        <article class="card card--flat scroll-reveal">
          <div class="board-card__header">
            <h3>员工负载</h3>
            <span class="badge">Staff</span>
          </div>
          <ul class="board-list">
            {staffLoad.map((item) => (
              <li>
                <div>
                  <strong>{item.employeeName}</strong>
                  <p>{item.petLabels}</p>
                </div>
                <div class="board-list__meta">
                  <span>{item.managedQty} 只</span>
                  <span>{formatCurrency(item.salary)}</span>
                </div>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="Navigation"
        title="功能模块"
        description="快速进入各业务模块查看详情和执行操作。"
      />

      <div class="grid grid--4">
        <a href="/pets" class="card card--flat nav-card scroll-reveal">
          <h3>宠物管理</h3>
          <p>宠物档案、状态、价格和库存信息。</p>
        </a>
        <a href="/inventory" class="card card--flat nav-card scroll-reveal">
          <h3>库存监控</h3>
          <p>库存数量、仓位、笼位和低库存预警。</p>
        </a>
        <a href="/preorders" class="card card--flat nav-card scroll-reveal">
          <h3>预约管理</h3>
          <p>预约状态流转、顾客预约记录。</p>
        </a>
        <a href="/employees" class="card card--flat nav-card scroll-reveal">
          <h3>员工管理</h3>
          <p>员工资料、工资和宠物分工。</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-matrix {
    display: grid;
    grid-template-columns: repeat(2, minmax(120px, 1fr));
    gap: var(--space-4);
    width: min(100%, 320px);
  }

  .hero-matrix__cell {
    border: var(--border-thick);
    box-shadow: var(--shadow-lg);
    min-height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 900;
    letter-spacing: var(--tracking-wide);
  }

  .hero-matrix__cell--accent {
    background: var(--color-accent);
  }

  .hero-matrix__cell--link {
    background: var(--color-link);
    color: var(--color-surface);
  }

  .hero-matrix__cell--action {
    background: var(--color-action);
    color: var(--color-surface);
  }

  .hero-matrix__cell--border {
    background: var(--color-border);
    color: var(--color-surface);
  }

  .featured-card__top,
  .board-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .featured-card__price {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    margin-bottom: var(--space-2);
  }

  .featured-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .board-list {
    display: grid;
    gap: var(--space-4);
  }

  .board-list li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-medium);
  }

  .board-list li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .board-list strong {
    display: block;
    margin-bottom: var(--space-2);
  }

  .board-list p {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .board-list__meta {
    display: grid;
    justify-items: end;
    gap: var(--space-2);
    text-align: right;
    font-size: var(--text-sm);
  }

  .nav-card {
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nav-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 1024px) {
    .board-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

