---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import PageHero from '@/components/PageHero.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import { apiCatalog, schemaModules } from '@/data/db';
---

<BaseLayout title="系统洞察" description="系统结构、接口与数据模块一览。">
  <PageHero
    eyebrow="System Insights"
    title="结构与接口"
    subtitle="页面结构、接口和数据模块的对应关系。"
    panelTitle="当前范围"
    stats={[
      { value: schemaModules.length, label: '数据模块' },
      { value: apiCatalog.length, label: 'API 接口' },
    ]}
  >
    <Button label="打开 /api/summary" href="/api/summary" />
    <Button label="回到首页" href="/" variant="ghost" />
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Schema Mapping"
        title="SQL schema 与页面模块"
        description="页面结构和接口字段围绕 petshop_schema.sql 的实体关系设计。"
      />

      <div class="grid grid--3">
        {schemaModules.map((item) => (
          <article class="card scroll-reveal">
            <p class="text-label">{item.table}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <div class="insight-tags">
              {item.fields.map((field) => (
                <code>{field}</code>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="API"
        title="接口列表"
        description="接口使用 TypeScript 编写，返回字段与页面读取逻辑对应。"
      />

      <div class="grid grid--3">
        {apiCatalog.map((item) => (
          <article class="card card--flat scroll-reveal">
            <p class="text-label">{item.name}</p>
            <h3>{item.path}</h3>
            <p>{item.description}</p>
            <a href={item.path}>打开接口</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .insight-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
