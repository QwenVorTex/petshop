---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import PageHero from '@/components/PageHero.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import StatusPill from '@/components/StatusPill.astro';
import { getRecentPreorders, getReservationBoard } from '@/data/db';
import { formatCurrency, formatDateTime } from '@/lib/format';

const board = await getReservationBoard();
const recentRows = await getRecentPreorders(6);
const activeCount = board.find((item) => item.status === '已预约')?.items.length ?? 0;
const waitingCount = board.find((item) => item.status === '待到店')?.items.length ?? 0;
const completedCount = board.find((item) => item.status === '已完成')?.items.length ?? 0;
---

<BaseLayout title="预约管理" description="顾客预约与预订流程页面。">
  <PageHero
    eyebrow="Reservation Board"
    title="预约流转看板"
    subtitle="预约按状态分列，同时展示最近处理记录。"
    panelTitle="预约概览"
    stats={[
      { value: activeCount, label: '已预约' },
      { value: waitingCount, label: '待到店' },
      { value: completedCount, label: '已完成' },
    ]}
    tone="link"
  >
    <Button label="查看接口" href="/api/preorders" />
    <Button label="查看顾客页" href="/customers" variant="ghost" />
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Kanban"
        title="状态看板"
        description="按状态分列的预约看板。"
      />

      <div class="kanban-grid">
        {board.map((column) => (
          <article class="card card--flat scroll-reveal">
            <div class="kanban-column__header">
              <h3>{column.status}</h3>
              <span class="badge">{column.items.length}</span>
            </div>

            <div class="kanban-column__items">
              {column.items.length > 0 ? (
                column.items.map((item) => (
                  <article class="kanban-ticket">
                    <StatusPill status={item.preorderStatus} />
                    <strong>{item.customerName}</strong>
                    <p>{item.petName} · {item.petSpecies}</p>
                    <p>{item.remark}</p>
                  </article>
                ))
              ) : (
                <p class="kanban-empty">当前没有记录。</p>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionIntro
        eyebrow="Timeline"
        title="最近处理记录"
        description="表格更接近数据库查询结果，可直接作为未来后台列表页的数据形态。"
      />

      <article class="card card--flat scroll-reveal">
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>顾客</th>
                <th>宠物</th>
                <th>状态</th>
                <th>预约时间</th>
                <th>数量</th>
                <th>金额</th>
              </tr>
            </thead>
            <tbody>
              {recentRows.map((item) => (
                <tr>
                  <td>{item.customerName}</td>
                  <td>
                    <strong>{item.petName}</strong>
                    <div>{item.petSpecies}</div>
                  </td>
                  <td><StatusPill status={item.preorderStatus} /></td>
                  <td>{formatDateTime(item.preorderTime)}</td>
                  <td>{item.preorderQty}</td>
                  <td>{formatCurrency(item.petPrice)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .kanban-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .kanban-column__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .kanban-column__items {
    display: grid;
    gap: var(--space-4);
  }

  .kanban-ticket {
    border: var(--border-medium);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
  }

  .kanban-ticket p {
    margin-bottom: 0;
  }

  .kanban-empty {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .kanban-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .kanban-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

